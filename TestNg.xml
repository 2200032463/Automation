<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AssetMS Automation Suite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="com.assetms.tests.MyListener"></listener>
    </listeners>

    <test name="AssetMS UI Tests - Chrome">
        <parameter name="browser" value="chrome"></parameter>
        <classes>
            <class name="com.assetms.tests.LoginTest"/>
            <class name="com.assetms.tests.AssetManagementTest"/>
        </classes>
    </test>

    <test name="AssetMS UI Tests - Edge">
        <parameter name="browser" value="edge"></parameter>
        <classes>
            <class name="com.assetms.tests.LoginTest"/>
            <class name="com.assetms.tests.AssetManagementTest"/>
        </classes>
    </test>
</suite>