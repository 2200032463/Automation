<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
╔══════════════════════════════════════════════════════════════════════════╗
║  AssetMS SANITY Suite  (TestNg_Sanity.xml)                             ║
║  13 Tests — one per module (quick smoke check, ~5-8 minutes)           ║
║  Runs ONLY tests tagged with the "sanity" group                        ║
╚══════════════════════════════════════════════════════════════════════════╝

  WHAT IS IN SANITY?
  One critical test per module that verifies the page loads / core action works.
  ─────────────────────────────────────────────────────────────────────────
  TC-S01 → testAdminLoginSuccess
  TC-S02 → testDashboardPageLoads
  TC-S03 → testEmployeeListLoads
  TC-S04 → testAssetManagementPageLoads
  TC-S05 → testAssetAssignmentPageLoads
  TC-S06 → testAssetTrackingPageLoads
  TC-S07 → testDetailsPageLoads
  TC-S08 → testTicketManagementPageLoads
  TC-S09 → testEmployeeDashboardLoads
  TC-S10 → testTicketPageLoadsForEmployee
  TC-S11 → testAdminLogout
  TC-S12 → testAssignedAssetsSectionExists
  TC-S13 → testAssetExistsBeforeDelete
  ─────────────────────────────────────────────────────────────────────────

  Run: mvn test -Dsurefire.suiteXmlFiles=TestNg_Sanity.xml
-->
<suite name="AssetMS Sanity Suite" parallel="classes" thread-count="2">

    <listeners>
        <listener class-name="com.assetms.tests.MyListener"/>
    </listeners>

    <test name="Sanity Tests - Chrome">
        <parameter name="browser" value="chrome"/>

        <groups>
            <run>
                <include name="sanity"/>
            </run>
        </groups>

        <classes>
            <class name="com.assetms.tests.LoginValidTest"/>
            <class name="com.assetms.tests.LoginInvalidTest"/>
            <class name="com.assetms.tests.AdminDashboardMetricsTest"/>
            <class name="com.assetms.tests.AdminDashboardListRefreshTest"/>
            <class name="com.assetms.tests.EmployeeGridSearchTest"/>
            <class name="com.assetms.tests.EmployeeDeletionConstraintsTest"/>
            <class name="com.assetms.tests.AssetCrudTest"/>
            <class name="com.assetms.tests.AssetCodeGenerationTest"/>
            <class name="com.assetms.tests.AssetAssignmentTest"/>
            <class name="com.assetms.tests.AssetTrackingTest"/>
            <class name="com.assetms.tests.RaiseTicketValidationTest"/>
            <class name="com.assetms.tests.TicketProcessingWorkflowTest"/>
            <class name="com.assetms.tests.EmployeeDashboardTest"/>
        </classes>
    </test>

</suite>
